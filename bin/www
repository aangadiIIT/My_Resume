#!/usr/bin/env node
/**
 * Akhilesh Angadi Portfolio — HTTP Server Bootstrap
 *
 * Normalises the port, creates the HTTP server from app.js, and attaches
 * error and listening lifecycle handlers.
 *
 * Responsibilities:
 *   1. Read PORT from environment (defaults to 3000)
 *   2. Attach EACCES / EADDRINUSE error handlers
 *   3. Log the bound address on successful listen
 *
 * Usage:
 *   node bin/www   (or via npm start → node scripts/update-summary.js && node bin/www)
 *
 * Author: Akhilesh Angadi
 */

/**
 * Module dependencies.
 */

var app    = require('../app');
var http   = require('http');
var statsStore  = require('../services/stats-store');
var resumeData  = require('../services/resume-data');

/**
 * Get port from environment and store in Express.
 */

var port = normalizePort(process.env.PORT || '3000');
app.set('port', port);

// Declare server at module scope so onListening() can reference it
var server = http.createServer(app);

/**
 * Eager-load data, then start listening.
 * Pre-loading resume data eliminates cold-start latency on first request.
 */
Promise.all([
  statsStore.loadStats(),
  resumeData.initialize(),
]).catch(err => {
  console.error('Startup data load error (continuing):', err.message);
}).then(() => {
  server.listen(port);
  server.on('error', onError);
  server.on('listening', onListening);

  // Graceful shutdown — drain active connections before exit
  process.on('SIGTERM', () => {
    console.log('[SERVER] SIGTERM received — shutting down gracefully...');
    server.close(() => {
      console.log('[SERVER] All connections closed. Exiting.');
      process.exit(0);
    });
    // Force exit after 30s if connections don't drain
    setTimeout(() => process.exit(1), 30_000);
  });
});

/**
 * Normalize a port into a number, string, or false.
 */

function normalizePort(val) {
  var port = parseInt(val, 10);

  if (isNaN(port)) {
    // named pipe
    return val;
  }

  if (port >= 0) {
    // port number
    return port;
  }

  return false;
}

/**
 * Event listener for HTTP server "error" event.
 */

function onError(error) {
  if (error.syscall !== 'listen') {
    throw error;
  }

  var bind = typeof port === 'string'
    ? 'Pipe ' + port
    : 'Port ' + port;

  // handle specific listen errors with friendly messages
  switch (error.code) {
    case 'EACCES':
      console.error(bind + ' requires elevated privileges');
      process.exit(1);
      break;
    case 'EADDRINUSE':
      console.error(bind + ' is already in use');
      process.exit(1);
      break;
    default:
      throw error;
  }
}

/**
 * Event listener for HTTP server "listening" event.
 */

function onListening() {
  var addr = server.address();
  var bind = typeof addr === 'string'
    ? 'pipe ' + addr
    : 'port ' + addr.port;
  console.log('Listening on ' + bind);
}
