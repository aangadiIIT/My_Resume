<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <div id="main-content" class="container py-5 my-4">
    <%- include('partials/page-header', {
      title: 'Certifications',
      subtitle: (data.certifications && data.certifications.certifications_summary)
        ? 'A continuous learning journey featuring ' + data.certifications.certifications_summary.total_certifications + ' certifications, primarily focused on ' + data.certifications.certifications_summary.dominant_category + '.'
        : 'Professional certifications and continuous learning milestones.'
    }) %>

    <% if(data.certifications && data.certifications.certifications && data.certifications.certifications.length > 0) { %>
      <div class="row g-4">
        <% data.certifications.certifications.forEach((cert, index) => { %>
          <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="<%= Math.min(index * 50, 400) %>">
            <div class="glass-card h-100 p-4 d-flex flex-column hover-lift border-top border-4" 
                 style="border-color: <%= cert.accentColor %> !important;">
              
              <div class="mb-3">
                <span class="badge bg-primary-soft text-primary mb-2 rounded-pill"><%= cert.category %></span>
                <h3 class="h5 fw-bold mb-1"><%= cert.name %></h3>
                <div class="text-muted small fw-bold">
                  <i class="fas fa-building me-1"></i> <%= cert.issuer %> 
                  <span class="mx-2">|</span> 
                  <i class="far fa-calendar-alt me-1"></i> <%= cert.issue_date %>
                </div>
              </div>

              <div class="mt-auto pt-3 border-top" style="border-color: var(--glass-border) !important;">
                <% if(cert.skills && cert.skills.length > 0) { %>
                  <div class="d-flex flex-wrap gap-1 mb-3">
                    <% cert.skills.forEach(skill => { %>
                      <span class="skill-pill" style="font-size: 0.75rem; padding: 0.2rem 0.6rem; margin: 0.1rem;"><%= skill %></span>
                    <% }) %>
                  </div>
                <% } %>
                
                <% if(cert.document_path) { %>
                  <div class="mt-3">
                    <button class="btn btn-sm btn-outline-primary rounded-pill w-100 fw-bold border-2 pdf-trigger" 
                            data-pdf="<%= cert.document_path %>" data-title="<%= cert.name %>">
                      <i class="far fa-file-pdf me-2"></i> View Certificate
                    </button>
                  </div>
                <% } %>
              </div>
              
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <%- include('partials/empty-state', { icon: 'fa-certificate', title: 'No certifications yet', message: 'Check back for updates.' }) %>
    <% } %>

    <%- include('partials/funnel-cta', { href: '/honors-awards', label: 'View Honors & Awards', heading: 'Recognitions & Achievements' }) %>

  </div>

  <%- include('partials/footer') %>
  <%- include('partials/pdf-viewer') %>

</body>
</html>
