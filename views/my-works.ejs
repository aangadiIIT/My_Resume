<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <div class="container py-5 my-4">
    <div class="text-center mb-5" data-aos="fade-down">
      <h1 class="section-title">Projects & Works</h1>
      <p class="lead text-muted max-w-2xl mx-auto">
        <% if(data.projects && data.projects.projects_summary) { %>
          Showcasing <%= data.projects.projects_summary.total_projects %> major projects spanning <%= data.projects.projects_summary.core_domains.join(', ') %>.
        <% } else { %>
          Showcasing my technical and academic projects.
        <% } %>
      </p>
    </div>

    <% if(data.projects && data.projects.projects) { %>
      <div class="projects-grid">
        <% data.projects.projects.forEach((proj, index) => { %>
          <div class="project-card" data-aos="fade-up" data-aos-delay="<%= Math.min(index * 100, 400) %>">
            <div class="glass-card d-flex flex-column h-100 p-4">
              
              <!-- Card Header -->
              <div class="mb-3 border-bottom pb-3" style="border-color: var(--glass-border) !important;">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <span class="badge bg-primary-soft text-primary rounded-pill px-3 py-1 fw-bold border border-primary border-opacity-25">
                    <%= proj.type %>
                  </span>
                  <span class="text-muted small fw-bold">
                    <i class="far fa-calendar-alt me-1"></i> <%= proj.duration.start %> - <%= proj.duration.end %>
                  </span>
                </div>
                <h3 class="h4 fw-bold text-gradient mt-2 mb-1"><%= proj.title %></h3>
                <h4 class="h6 fw-bold text-muted"><i class="fas fa-sitemap me-1"></i> <%= proj.organization %></h4>
              </div>

              <!-- Card Body (Description) -->
              <div class="project-content mb-3">
                <p class="text-muted small mb-3">
                  <%= proj.summary %>
                </p>

                <!-- Accordion for detailed info -->
                <div class="accordion custom-accordion" id="accordionProject<%= index %>">
                  <% if(proj.problem_statement && proj.problem_statement.length > 0) { %>
                  <div class="accordion-item">
                    <h2 class="accordion-header">
                      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseProb<%= index %>">
                        <i class="fas fa-exclamation-circle text-warning me-2"></i> Problem Statement
                      </button>
                    </h2>
                    <div id="collapseProb<%= index %>" class="accordion-collapse collapse" data-bs-parent="#accordionProject<%= index %>">
                      <div class="accordion-body small pl-4">
                        <ul class="mb-0 ps-3">
                          <% proj.problem_statement.forEach(item => { %>
                            <li><%= item %></li>
                          <% }) %>
                        </ul>
                      </div>
                    </div>
                  </div>
                  <% } %>

                  <% if(proj.solution && proj.solution.length > 0) { %>
                  <div class="accordion-item">
                    <h2 class="accordion-header">
                      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSol<%= index %>">
                        <i class="fas fa-lightbulb text-success me-2"></i> Solution & Workflow
                      </button>
                    </h2>
                    <div id="collapseSol<%= index %>" class="accordion-collapse collapse" data-bs-parent="#accordionProject<%= index %>">
                      <div class="accordion-body small">
                        <ul class="mb-2 ps-3">
                          <% proj.solution.forEach(item => { %>
                            <li><%= item %></li>
                          <% }) %>
                        </ul>
                        <% if(proj.workflow && proj.workflow.length > 0) { %>
                          <strong class="text-accent mt-2 d-block">Workflow:</strong>
                          <ol class="mb-0 ps-3">
                            <% proj.workflow.forEach(item => { %>
                              <li><%= item %></li>
                            <% }) %>
                          </ol>
                        <% } %>
                      </div>
                    </div>
                  </div>
                  <% } %>

                  <% if(proj.impact && proj.impact.length > 0) { %>
                  <div class="accordion-item">
                    <h2 class="accordion-header">
                      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseImpact<%= index %>">
                        <i class="fas fa-chart-line text-primary me-2"></i> Impact
                      </button>
                    </h2>
                    <div id="collapseImpact<%= index %>" class="accordion-collapse collapse" data-bs-parent="#accordionProject<%= index %>">
                      <div class="accordion-body small">
                        <ul class="mb-0 ps-3">
                          <% proj.impact.forEach(item => { %>
                            <li><%= item %></li>
                          <% }) %>
                        </ul>
                      </div>
                    </div>
                  </div>
                  <% } %>
                </div>
              </div>

              <!-- Tech Stack Container (Flex wrap at bottom) -->
              <div class="mt-auto pt-3 border-top" style="border-color: var(--glass-border) !important;">
                <% if(proj.technologies && proj.technologies.length > 0) { %>
                  <div class="d-flex flex-wrap gap-1">
                    <% proj.technologies.forEach(tech => { %>
                      <span class="skill-pill" style="font-size: 0.8rem; padding: 0.3rem 0.8rem;"><%= tech %></span>
                    <% }) %>
                  </div>
                <% } %>
              </div>

            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <!-- Funnel Navigation CTA -->
    <div class="mt-5 pt-5 border-top text-center" style="border-color: var(--glass-border) !important;" data-aos="fade-up">
      <p class="text-muted fw-bold text-uppercase tracking-widest mb-2">Next Chapter</p>
      <h3 class="h2 fw-bolder mb-4">Discover My Technical Arsenal</h3>
      <a href="/my-skills" class="btn-primary-custom px-5 py-3 fs-5 shadow-sm">
        View My Skills <i class="fas fa-arrow-right ms-2"></i>
      </a>
    </div>

  </div>

  <%- include('partials/footer') %>
</body>
</html>
