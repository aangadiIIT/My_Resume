<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('partials/head') %>
</head>

<body>
  <%- include('partials/header') %>

    <div class="container py-5 my-4 min-vh-75 d-flex flex-column justify-content-center">
      <div class="text-center mb-5" data-aos="fade-down">
        <h1 class="section-title">Get In Touch</h1>
        <p class="lead text-muted max-w-2xl mx-auto">Have an exciting opportunity, a technical question, or just want to
          say hi? My inbox is always open.</p>
      </div>

      <div class="row g-5">
        <!-- Left Column: Contact Info -->
        <div class="col-lg-5" data-aos="fade-right">
          <div class="d-flex flex-column gap-4">

            <div class="glass-card p-4 border-start border-4 border-primary">
              <div class="d-flex align-items-center">
                <div class="d-flex align-items-center justify-content-center rounded-circle me-3"
                  style="width: 50px; height: 50px; background: var(--shape-1); color: var(--accent-primary); font-size: 1.2rem;">
                  <i class="fas fa-envelope"></i>
                </div>
                <div>
                  <h3 class="h6 fw-bold mb-1 text-muted text-uppercase">Email</h3>
                  <a href="mailto:<%= data.profile.profile.contact.email %>"
                    class="fw-bold fs-6 text-primary text-decoration-none">
                    <%= data.profile.profile.contact.email %>
                  </a>
                </div>
              </div>
            </div>

            <div class="glass-card p-4 border-start border-4" style="border-color: #8b5cf6 !important;">
              <div class="d-flex align-items-center">
                <div class="d-flex align-items-center justify-content-center rounded-circle me-3"
                  style="width: 50px; height: 50px; background: var(--shape-2); color: #8b5cf6; font-size: 1.2rem;">
                  <i class="fas fa-map-marker-alt"></i>
                </div>
                <div>
                  <h3 class="h6 fw-bold mb-1 text-muted text-uppercase">Location</h3>
                  <span class="fw-bold fs-6" style="color: #8b5cf6;">
                    <%= data.profile.profile.contact.location_current %>
                  </span>
                </div>
              </div>
            </div>

            <div class="glass-card p-4">
              <h3 class="h6 fw-bold mb-3 text-muted text-uppercase border-bottom pb-2">Connect</h3>
              <div class="d-flex gap-3">
                <% if(data.profile.profile.social_links && data.profile.profile.social_links.linkedin) { %>
                  <a href="<%= data.profile.profile.social_links.linkedin %>" target="_blank"
                    class="btn btn-outline-primary rounded-circle d-flex align-items-center justify-content-center"
                    style="width: 45px; height: 45px;"><i class="fab fa-linkedin-in fs-5"></i></a>
                  <% } %>
                    <% if(data.profile.profile.social_links && data.profile.profile.social_links.github) { %>
                      <a href="<%= data.profile.profile.social_links.github %>" target="_blank"
                        class="btn btn-outline-secondary rounded-circle d-flex align-items-center justify-content-center"
                        style="width: 45px; height: 45px; color: var(--text-primary); border-color: var(--border-color);"><i
                          class="fab fa-github fs-5"></i></a>
                      <% } %>
              </div>
            </div>

            <div class="glass-card p-4 text-center">
              <p class="small text-muted mb-3 italic">"Good design is a conversation."</p>
              <a href="/view-asset/documents/Resume.pdf" class="btn-outline-custom w-100 text-decoration-none"
                download="Resume.pdf" style="font-size: 0.9rem;">
                <i class="fas fa-file-pdf me-2"></i> Download Formal CV
              </a>
            </div>

          </div>
        </div>

        <!-- Right Column: Contact Form -->
        <div class="col-lg-7" data-aos="fade-left">
          <div class="glass-card p-5 h-100">
            <h3 class="h4 fw-bold mb-1 text-gradient">Send a Message</h3>
            <p class="text-muted small mb-4">I'll respond as soon as I see your notification.</p>

            <form action="/contact-me" method="POST" class="custom-form">
              <div class="row g-4">
                <div class="col-md-6">
                  <div class="form-group">
                    <label class="form-label small fw-bold text-muted">Full Name</label>
                    <input type="text" name="name" class="form-control glass-input" placeholder="Your Name" required>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="form-group">
                    <label class="form-label small fw-bold text-muted">Email Address</label>
                    <input type="email" name="email" class="form-control glass-input" placeholder="email@example.com"
                      required>
                  </div>
                </div>
                <div class="col-12">
                  <div class="form-group">
                    <label class="form-label small fw-bold text-muted">Subject</label>
                    <input type="text" name="subject" class="form-control glass-input" placeholder="What is this about?"
                      required>
                  </div>
                </div>
                <div class="col-12">
                  <div class="form-group">
                    <label class="form-label small fw-bold text-muted">Message</label>
                    <textarea name="message" rows="5" class="form-control glass-input"
                      placeholder="Your message here..." required></textarea>
                  </div>
                </div>
                <div class="col-12 mt-4">
                  <button type="submit" class="btn-primary-custom w-100 py-3 fs-5 shadow-sm">
                    Send Message <i class="fas fa-paper-plane ms-2"></i>
                  </button>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>

      <!-- Feedback Section -->
      <div class="row mt-5" data-aos="fade-up">
        <div class="col-12">
          <%- include('partials/feedback-form') %>
        </div>
      </div>
    </div>

    <%- include('partials/footer') %>
</body>

</html>