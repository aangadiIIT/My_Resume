<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <style>
    .rec-author-img {
      width: 80px;
      height: 80px;
      object-fit: cover;
      border: 3px solid var(--accent-primary);
      padding: 3px;
    }
    .strength-tag {
      font-size: 0.8rem;
      padding: 0.4rem 0.8rem;
      background: rgba(var(--bs-primary-rgb), 0.05);
      border: 1px solid rgba(var(--bs-primary-rgb), 0.1);
      border-radius: 50px;
      color: var(--text-muted);
      transition: all 0.3s ease;
    }
    .strength-tag:hover {
      background: var(--accent-primary);
      color: white;
      transform: translateY(-2px);
    }
  </style>
</head>
<body>
  <%- include('partials/header') %>

  <div class="container py-5 my-4">
    <div class="text-center mb-5" data-aos="fade-down">
      <h1 class="section-title">Professional Recommendations</h1>
      <p class="lead text-muted max-w-2xl mx-auto">
        <% if(data.recommendations && data.recommendations.recommendations_summary) { %>
          Vouched for by <%= data.recommendations.recommendations_summary.total_recommendations %> industry leaders across <%= data.recommendations.recommendations_summary.sources.join(', ') %>.
        <% } else { %>
          Testimonials and endorsements from my colleagues and managers.
        <% } %>
      </p>
    </div>

    <% if(data.recommendations && data.recommendations.recommendations) { %>
      <div class="row g-5">
        <% data.recommendations.recommendations.forEach((rec, index) => { %>
          <div class="col-12" data-aos="fade-up" data-aos-delay="<%= index * 100 %>">
            <div class="glass-card p-4 p-md-5 position-relative overflow-hidden">
              
              <div class="row align-items-center mb-4">
                <div class="col-md-auto text-center text-md-start mb-3 mb-md-0">
                  <div class="bg-primary-soft rounded-circle d-inline-flex align-items-center justify-content-center shadow-sm" style="width: 80px; height: 80px;">
                    <i class="fas fa-user-tie text-primary fs-2"></i>
                  </div>
                </div>
                <div class="col text-center text-md-start">
                  <h2 class="h3 fw-bold mb-1 text-gradient"><%= rec.author.name %></h2>
                  <p class="text-primary fw-bold mb-0"><%= rec.author.role %></p>
                  <p class="text-muted small mb-0">
                    <span class="fw-bold"><%= rec.author.company %></span> 
                    <% if(rec.author.additional_info) { %> | <%= rec.author.additional_info %><% } %>
                  </p>
                  <div class="mt-2 text-muted small">
                    <span class="badge bg-light text-dark border me-2"><i class="fas fa-link me-1"></i> <%= rec.author.relationship %></span>
                    <span class="badge bg-light text-dark border"><i class="far fa-calendar-alt me-1"></i> <%= rec.date %></span>
                  </div>
                </div>
              </div>

              <div class="mb-4">
                <div class="position-relative border-start border-4 border-primary-soft ps-4">
                  <i class="fas fa-quote-left text-primary opacity-25 fs-4 mb-3 d-block"></i>
                  <div class="fst-italic text-muted" style="line-height: 1.8; font-size: 1.1rem; text-align: justify;">
                    <%- rec.recommendation_raw.replace(/\n\n/g, '</div><div class="mt-3 fst-italic text-muted" style="line-height: 1.8; font-size: 1.1rem; text-align: justify;">') %>
                  </div>
                </div>
              </div>

              <div class="pt-4 border-top" style="border-color: var(--glass-border) !important;">
                <div class="row g-4">
                  <div class="col-md-8">
                    <h5 class="small fw-bold text-uppercase tracking-wider text-primary mb-3">Key Strengths Highlighted</h5>
                    <div class="d-flex flex-wrap gap-2">
                      <% rec.strengths_highlighted.forEach(strength => { %>
                        <span class="strength-tag"><%= strength %></span>
                      <% }) %>
                    </div>
                  </div>
                  <div class="col-md-4">
                    <h5 class="small fw-bold text-uppercase tracking-wider text-primary mb-3">Impact Tags</h5>
                    <div class="d-flex flex-wrap gap-2">
                      <% rec.impact_keywords.forEach(keyword => { %>
                        <span class="badge bg-primary text-white rounded-pill px-3 py-2" style="font-size: 0.7rem;">#<%= keyword %></span>
                      <% }) %>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <!-- Funnel Navigation CTA -->
    <div class="mt-5 pt-5 border-top text-center" style="border-color: var(--glass-border) !important;" data-aos="fade-up">
      <p class="text-muted fw-bold text-uppercase tracking-widest mb-2">Next Chapter</p>
      <h3 class="h2 fw-bolder mb-4">Academic & Research Value</h3>
      <a href="/publications" class="btn-primary-custom px-5 py-3 fs-5 shadow-sm">
        View Publications <i class="fas fa-book-open ms-2"></i>
      </a>
    </div>

  </div>

  <%- include('partials/footer') %>
</body>
</html>
