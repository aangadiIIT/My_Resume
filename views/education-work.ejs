<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <div class="container py-5 my-4">
    <div class="text-center mb-5" data-aos="fade-down">
      <h1 class="section-title">Work Experience</h1>
      <p class="lead text-muted max-w-2xl mx-auto">
        <% if(data.experience && data.experience.experience_summary) { %>
          Tracing my journey across <%= data.experience.experience_summary.companies_worked.join(', ') %>, leading to over <%= data.experience.experience_summary.total_years_experience %> of building robust systems.
        <% } else { %>
          Tracing my professional journey.
        <% } %>
      </p>
    </div>

    <% if(data.experience && data.experience.experience) { %>
      <div class="vertical-timeline" data-aos="fade-up">
        <% data.experience.experience.forEach((job, index) => { %>
          <div class="timeline-item" data-aos="fade-up" data-aos-delay="<%= Math.min(index * 100, 500) %>">
            <div class="glass-card p-4 p-lg-5">
              <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 border-bottom pb-3" style="border-color: var(--glass-border) !important;">
                <div>
                  <h3 class="h4 fw-bold text-gradient mb-1"><%= job.role %></h3>
                  <h4 class="h6 fw-bold mb-2 text-primary">
                    <i class="fas fa-building me-1"></i> <%= job.company %> 
                    <span class="badge bg-secondary ms-2 fw-normal"><%= job.employment_type %></span>
                  </h4>
                </div>
                <div class="text-md-end mt-2 mt-md-0">
                  <div class="timeline-date d-block mb-1">
                    <i class="fas fa-calendar-alt me-1"></i> 
                    <%= job.duration.start %> - <%= job.duration.end %>
                  </div>
                  <div class="text-muted small">
                    <i class="fas fa-map-marker-alt me-1"></i> <%= job.location %>
                  </div>
                </div>
              </div>

              <!-- Roles & Responsibilities -->
              <div class="mb-4">
                <p class="text-muted mb-3"><%= job.summary %></p>
                <h5 class="h6 fw-bold text-primary mb-2">Key Responsibilities</h5>
                <ul class="icon-list">
                  <% job.responsibilities.forEach(resp => { %>
                    <li><%= resp %></li>
                  <% }) %>
                </ul>
              </div>

              <!-- Impact -->
              <% if(job.impact && job.impact.length > 0) { %>
                <div class="mb-4 p-3 rounded" style="background: var(--shape-1); border: 1px dashed var(--accent-primary);">
                  <h5 class="h6 fw-bold text-accent mb-2"><i class="fas fa-chart-line me-2"></i> Business Impact</h5>
                  <ul class="text-muted small mb-0 ps-3">
                    <% job.impact.forEach(imp => { %>
                      <li class="mb-1"><%= imp %></li>
                    <% }) %>
                  </ul>
                </div>
              <% } %>

              <!-- Technologies Stack -->
              <% if(job.technologies && job.technologies.length > 0) { %>
                <div class="pt-2">
                  <span class="small fw-bold text-muted me-2 d-inline-block mt-2">Tech Stack:</span>
                  <% job.technologies.forEach(tech => { %>
                    <span class="skill-pill"><%= tech %></span>
                  <% }) %>
                </div>
              <% } %>
              
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <!-- Funnel Navigation CTA -->
    <div class="mt-5 pt-5 border-top text-center" style="border-color: var(--glass-border) !important;" data-aos="fade-up">
      <p class="text-muted fw-bold text-uppercase tracking-widest mb-2">Next Chapter</p>
      <h3 class="h2 fw-bolder mb-4">See What I've Built</h3>
      <a href="/my-works" class="btn-primary-custom px-5 py-3 fs-5 shadow-sm">
        View My Projects <i class="fas fa-arrow-right ms-2"></i>
      </a>
    </div>

  </div>

  <%- include('partials/footer') %>
</body>
</html>
