<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body class="d-flex flex-column min-vh-100">
  <%- include('partials/header') %>

  <div class="container text-center py-5 my-auto flex-grow-1 d-flex flex-column justify-content-center align-items-center">
    <div class="glass-card d-inline-block px-5 py-5 text-center shadow-lg" data-aos="zoom-in">
      <div class="mb-4 text-primary" style="font-size: 5rem;">
        <i class="fas fa-exclamation-triangle opacity-50"></i>
      </div>
      <h1 class="display-1 fw-bold text-gradient mb-2"><%= error.status || '500' %></h1>
      <h2 class="h4 mb-4 text-muted"><%= message || 'Something went wrong.' %></h2>
      <a href="/" class="btn-primary-custom mt-2 d-inline-block">
        <i class="fas fa-arrow-left me-2"></i> Back to Homepage
      </a>
      
      <% if(error.stack && process.env.NODE_ENV === 'development') { %>
        <pre class="text-start bg-dark text-light p-3 mt-4 rounded small overflow-auto" style="max-height: 200px;"><%= error.stack %></pre>
      <% } %>
    </div>
  </div>

  <%- include('partials/footer') %>
</body>
</html>
