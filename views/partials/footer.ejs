<%#
  Akhilesh Angadi Portfolio — Footer Partial

  Renders the site footer (social links, copyright), the Recruiter FAB
  (floating action button with contact/why-hire quick actions), and all
  global initialisation scripts (AOS animations, Bootstrap tooltips, theme
  toggle, UIManager, CommandPalette).

  Data contract (locals expected):
    - data.profile.profile.social_links  — GitHub, LinkedIn URLs
    - nonce                              — CSP nonce for all inline <script> blocks

  Author: Akhilesh Angadi
%>
<link rel="stylesheet" href="/stylesheets/command-palette.css">

<footer class="custom-footer">
  <div class="container text-center">
    <div class="d-flex justify-content-center mb-4">
      <% if(data.profile.profile.social_links && data.profile.profile.social_links.linkedin) { %>
        <a href="<%= data.profile.profile.social_links.linkedin %>" target="_blank" rel="noopener noreferrer" class="social-icon-btn"><i
            class="fab fa-linkedin-in"></i></a>
        <% } %>

          <% if(data.profile.profile.social_links && data.profile.profile.social_links.github) { %>
            <a href="<%= data.profile.profile.social_links.github %>" target="_blank" rel="noopener noreferrer" class="social-icon-btn"><i
                class="fab fa-github"></i></a>
            <% } %>

              <% if(data.profile.profile.contact && data.profile.profile.contact.email) { %>
                <a href="mailto:<%= data.profile.profile.contact.email %>" class="social-icon-btn"><i
                    class="fas fa-envelope"></i></a>
                <% } %>
    </div>

    <!-- <p class="mb-1 fw-medium h5 text-primary"><%= data.profile.profile.name %></p> -->
    <p class="text-muted small mb-0">&copy; <%= new Date().getFullYear() %>
        <%= data.profile.profile.name %>. All Rights Reserved.</p>
    <p class="text-secondary opacity-50 x-small mt-1" style="font-size: 0.65rem;">Cloud & DevOps Solutions Portfolio</p>
  </div>
</footer>

<!-- Recruiter FAB -->
<div class="recruiter-fab" id="recruiterFab" title="Recruiter Options">
  <div class="fab-pulse"></div>
  <div class="fab-menu" id="fabMenu">
    <button class="menu-item why" id="fabWhyBtn" aria-label="Ask why you should hire Akhilesh">
      <i class="fas fa-question-circle" aria-hidden="true"></i>
      <span class="menu-label">Why?</span>
    </button>
    <button class="menu-item contact" id="fabContactBtn" aria-label="Contact Akhilesh about hiring">
      <i class="fas fa-envelope" aria-hidden="true"></i>
      <span class="menu-label">Contact</span>
    </button>
  </div>
  <button class="fab-btn" id="recruiterFabMainBtn" aria-label="Open recruiter menu" aria-expanded="false" aria-controls="fabMenu">
    <i class="fas fa-bullseye" aria-hidden="true"></i>
    <span class="fab-text">Hire Him</span>
  </button>
</div>

<style nonce="<%= nonce %>">
.recruiter-fab {
  position: fixed;
  bottom: 90px;
  right: 25px;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.fab-pulse {
  position: absolute;
  width: 100%;
  height: 100%;
  background: var(--accent-primary);
  border-radius: 50px;
  opacity: 0.6;
  animation: fabPulse 2s infinite;
}
@keyframes fabPulse {
  0% { transform: scale(0.95); opacity: 0.7; }
  70% { transform: scale(1.3); opacity: 0; }
  100% { transform: scale(0.95); opacity: 0; }
}
.fab-btn {
  position: relative;
  background: var(--accent-gradient);
  color: white;
  border: none;
  padding: 12px 20px;
  border-radius: 50px;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 8px;
  box-shadow: 0 10px 25px rgba(37, 99, 235, 0.4);
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  cursor: pointer;
  overflow: hidden;
}
.fab-btn:hover {
  transform: translateY(-5px) scale(1.05);
  box-shadow: 0 15px 30px rgba(37, 99, 235, 0.6);
}
.fab-btn i { font-size: 1.1rem; transition: transform 0.3s; }
.fab-text { font-size: 0.9rem; letter-spacing: 0.5px; }

/* FAB Menu */
.fab-menu {
  position: absolute;
  bottom: 100%;
  right: 0;
  margin-bottom: 20px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  opacity: 0;
  visibility: hidden;
  transform: translateY(20px);
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.recruiter-fab.active .fab-menu {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}
.recruiter-fab.active .fab-btn i { transform: rotate(180deg); }

.menu-item {
  background: var(--glass-bg);
  border: 1px solid var(--glass-border);
  backdrop-filter: blur(8px);
  color: var(--text-primary);
  padding: 10px 18px;
  border-radius: 50px;
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  box-shadow: 0 5px 15px rgba(0,0,0,0.1);
  transition: all 0.2s;
  white-space: nowrap;
}
.menu-item:hover {
  background: var(--accent-gradient);
  color: white;
  transform: scale(1.05);
  border-color: transparent;
}
.menu-item.why i { color: #facc15; }
.menu-item.contact i { color: #60a5fa; }
.menu-item:hover i { color: white; }

@media (max-width: 768px) {
  .recruiter-fab { bottom: 85px; right: 20px; }
  .fab-text { display: none; }
  .fab-btn { padding: 12px; border-radius: 50%; width: 50px; height: 50px; justify-content: center; }
  .menu-item .menu-label { display: none; }
  .menu-item { padding: 12px; border-radius: 50%; width: 45px; height: 45px; justify-content: center; }
}
</style>

<script nonce="<%= nonce %>">
document.addEventListener('DOMContentLoaded', () => {
  const fabContainer = document.getElementById('recruiterFab');
  const mainBtn = document.getElementById('recruiterFabMainBtn');
  const whyBtn = document.getElementById('fabWhyBtn');
  const contactBtn = document.getElementById('fabContactBtn');

  if (mainBtn) {
    mainBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpening = !fabContainer.classList.contains('active');
      if (isOpening && typeof UIManager !== 'undefined') UIManager.closeAll('fab');
      fabContainer.classList.toggle('active');
    });
  }

  if (whyBtn) {
    whyBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      fabContainer.classList.remove('active');
      if (typeof toggleChat === 'function') {
        toggleChat();
        const input = document.getElementById('chatInput');
        if (input) {
          input.value = "Why hire him?";
          // Delay send to ensure bot is ready
          setTimeout(() => { if (typeof handleChatSend === 'function') handleChatSend(); }, 100);
        }
      }
    });
  }

  if (contactBtn) {
    contactBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      fabContainer.classList.remove('active');
      if (typeof openHiringPopup === 'function') openHiringPopup();
    });
  }
});
</script>

<!-- Chart.js — needed on all pages for the global metrics widget gauges -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" integrity="sha384-e6nUZLBkQ86NJ6TVVKAeSaK8jWa3NhkYWZFomE39AvDbQWeie9PlQqM3pmYW5d1g" crossorigin="anonymous"></script>
<!-- Bootstrap JS — always needed (modals, dropdowns, collapse) -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
<!-- AOS Animation JS — only on pages with AOS animations -->
<% if (typeof pageType === 'undefined' || pageType === 'index' || pageType === 'experience') { %>
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js" integrity="sha384-wziAfh6b/qT+3LrqebF9WeK4+J5sehS6FA10J1t3a866kJ/fvU5UwofWnQyzLtwu" crossorigin="anonymous"></script>
<% } %>
<!-- Typed.js — only on index (hero typing animation) -->
<% if (typeof pageType === 'undefined' || pageType === 'index') { %>
<script src="https://cdn.jsdelivr.net/npm/typed.js@2.0.12/lib/typed.umd.js" integrity="sha384-TNyi8lSKoLLAVU5tQFSHZ14ywIbDcjAXR2PNwWak3nVxNVJqjkzeO0Ap1MieQb69" crossorigin="anonymous"></script>
<% } %>

<!-- Global init: AOS, scroll handlers, theme toggle -->
<script src="/scripts/toast.js"></script>
<script src="/scripts/footer-init.js"></script>
<%- include('metrics-widget') %>

<%- include('hiring-popup') %>
<%- include('feedback-popup') %>
<%- include('chatbot') %>
<script src="/scripts/ui-manager.js"></script>
<script src="/scripts/command-palette.js"></script>
