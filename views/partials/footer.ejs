<link rel="stylesheet" href="/stylesheets/command-palette.css">

<footer class="custom-footer">
  <div class="container text-center">
    <div class="d-flex justify-content-center mb-4">
      <% if(data.profile.profile.social_links && data.profile.profile.social_links.linkedin) { %>
        <a href="<%= data.profile.profile.social_links.linkedin %>" target="_blank" class="social-icon-btn"><i
            class="fab fa-linkedin-in"></i></a>
        <% } %>

          <% if(data.profile.profile.social_links && data.profile.profile.social_links.github) { %>
            <a href="<%= data.profile.profile.social_links.github %>" target="_blank" class="social-icon-btn"><i
                class="fab fa-github"></i></a>
            <% } %>

              <% if(data.profile.profile.contact && data.profile.profile.contact.email) { %>
                <a href="mailto:<%= data.profile.profile.contact.email %>" class="social-icon-btn"><i
                    class="fas fa-envelope"></i></a>
                <% } %>
    </div>

    <!-- <p class="mb-1 fw-medium h5 text-primary"><%= data.profile.profile.name %></p> -->
    <p class="text-muted small mb-0">&copy; <%= new Date().getFullYear() %>
        <%= data.profile.profile.name %>. All Rights Reserved.</p>
    <p class="text-secondary opacity-50 x-small mt-1" style="font-size: 0.65rem;">Cloud & DevOps Solutions Portfolio</p>
  </div>
</footer>

<!-- Recruiter FAB -->
<div class="recruiter-fab" id="recruiterFab" title="Recruiter Options">
  <div class="fab-pulse"></div>
  <div class="fab-menu" id="fabMenu">
    <button class="menu-item why" id="fabWhyBtn">
      <i class="fas fa-question-circle"></i>
      <span class="menu-label">Why?</span>
    </button>
    <button class="menu-item contact" id="fabContactBtn">
      <i class="fas fa-envelope"></i>
      <span class="menu-label">Contact</span>
    </button>
  </div>
  <button class="fab-btn" id="recruiterFabMainBtn">
    <i class="fas fa-bullseye"></i>
    <span class="fab-text">Hire Him</span>
  </button>
</div>

<style>
.recruiter-fab {
  position: fixed;
  bottom: 90px;
  right: 25px;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.fab-pulse {
  position: absolute;
  width: 100%;
  height: 100%;
  background: var(--accent-primary);
  border-radius: 50px;
  opacity: 0.6;
  animation: fabPulse 2s infinite;
}
@keyframes fabPulse {
  0% { transform: scale(0.95); opacity: 0.7; }
  70% { transform: scale(1.3); opacity: 0; }
  100% { transform: scale(0.95); opacity: 0; }
}
.fab-btn {
  position: relative;
  background: var(--accent-gradient);
  color: white;
  border: none;
  padding: 12px 20px;
  border-radius: 50px;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 8px;
  box-shadow: 0 10px 25px rgba(37, 99, 235, 0.4);
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  cursor: pointer;
  overflow: hidden;
}
.fab-btn:hover {
  transform: translateY(-5px) scale(1.05);
  box-shadow: 0 15px 30px rgba(37, 99, 235, 0.6);
}
.fab-btn i { font-size: 1.1rem; transition: transform 0.3s; }
.fab-text { font-size: 0.9rem; letter-spacing: 0.5px; }

/* FAB Menu */
.fab-menu {
  position: absolute;
  bottom: 100%;
  right: 0;
  margin-bottom: 20px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  opacity: 0;
  visibility: hidden;
  transform: translateY(20px);
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.recruiter-fab.active .fab-menu {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}
.recruiter-fab.active .fab-btn i { transform: rotate(180deg); }

.menu-item {
  background: var(--glass-bg);
  border: 1px solid var(--glass-border);
  backdrop-filter: blur(8px);
  color: var(--text-primary);
  padding: 10px 18px;
  border-radius: 50px;
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  box-shadow: 0 5px 15px rgba(0,0,0,0.1);
  transition: all 0.2s;
  white-space: nowrap;
}
.menu-item:hover {
  background: var(--accent-gradient);
  color: white;
  transform: scale(1.05);
  border-color: transparent;
}
.menu-item.why i { color: #facc15; }
.menu-item.contact i { color: #60a5fa; }
.menu-item:hover i { color: white; }

@media (max-width: 768px) {
  .recruiter-fab { bottom: 85px; right: 20px; }
  .fab-text { display: none; }
  .fab-btn { padding: 12px; border-radius: 50%; width: 50px; height: 50px; justify-content: center; }
  .menu-item .menu-label { display: none; }
  .menu-item { padding: 12px; border-radius: 50%; width: 45px; height: 45px; justify-content: center; }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const fabContainer = document.getElementById('recruiterFab');
  const mainBtn = document.getElementById('recruiterFabMainBtn');
  const whyBtn = document.getElementById('fabWhyBtn');
  const contactBtn = document.getElementById('fabContactBtn');

  if (mainBtn) {
    mainBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpening = !fabContainer.classList.contains('active');
      if (isOpening && typeof UIManager !== 'undefined') UIManager.closeAll('fab');
      fabContainer.classList.toggle('active');
    });
  }

  if (whyBtn) {
    whyBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      fabContainer.classList.remove('active');
      if (typeof toggleChat === 'function') {
        toggleChat();
        const input = document.getElementById('chatInput');
        if (input) {
          input.value = "Why hire him?";
          // Delay send to ensure bot is ready
          setTimeout(() => { if (typeof handleChatSend === 'function') handleChatSend(); }, 100);
        }
      }
    });
  }

  if (contactBtn) {
    contactBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      fabContainer.classList.remove('active');
      if (typeof openHiringPopup === 'function') openHiringPopup();
    });
  }
});
</script>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<!-- AOS Animation JS -->
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<!-- Typed.js -->
<script src="https://cdn.jsdelivr.net/npm/typed.js@2.0.12"></script>

<!-- Global Scripts -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Initialize AOS
    if (typeof AOS !== 'undefined') {
      AOS.init({
        duration: 800,
        once: true,
        offset: 100,
        easing: 'ease-out-cubic'
      });
    }

    // 2. Global Scroll Progress
    const scrollProgress = document.getElementById('scroll-progress');
    if (scrollProgress) {
      window.addEventListener('scroll', () => {
        const windowHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrollPosition = document.documentElement.scrollTop || document.body.scrollTop;
        const scrollPercentage = Math.min(100, Math.max(0, (scrollPosition / windowHeight) * 100));
        scrollProgress.style.width = scrollPercentage + '%';
      });
    }

    // 2. Navbar Scroll Effect
    const navbar = document.getElementById('main-nav');
    if (navbar) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
          navbar.classList.add('scrolled');
        } else {
          navbar.classList.remove('scrolled');
        }
      });
    }

    // 3. Theme Toggle Logic
    const themeToggle = document.getElementById('theme-toggle');
    if (themeToggle) {
      const icon = themeToggle.querySelector('i');

      const currentTheme = localStorage.getItem('theme') || 'light';
      if (currentTheme === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
        icon.classList.replace('fa-moon', 'fa-sun');
      }

      themeToggle.addEventListener('click', () => {
        let theme = document.documentElement.getAttribute('data-theme');
        if (theme === 'dark') {
          document.documentElement.removeAttribute('data-theme');
          localStorage.setItem('theme', 'light');
          icon.classList.replace('fa-sun', 'fa-moon');
        } else {
          document.documentElement.setAttribute('data-theme', 'dark');
          localStorage.setItem('theme', 'dark');
          icon.classList.replace('fa-moon', 'fa-sun');
        }
      });
    }
  });
</script>
