<div class="feedback-form-container glass-card p-4">
  <div class="feedback-content" id="pageFeedbackFormStep">
    <div class="d-flex align-items-center gap-3 mb-4">
      <div class="fs-1">📝</div>
      <div>
        <h4 class="fw-bold mb-1">Detailed Feedback</h4>
        <p class="text-muted small mb-0">Help me improve by providing your detailed thoughts.</p>
      </div>
    </div>
    
    <form id="pageFeedbackForm">
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label small fw-bold">Name</label>
          <input type="text" name="name" class="form-control glass-input" placeholder="Enter your name" required>
        </div>
        <div class="col-md-6">
          <label class="form-label small fw-bold">Email</label>
          <input type="email" name="email" class="form-control glass-input" placeholder="Enter your email" required>
        </div>
        <div class="col-12">
          <label class="form-label small fw-bold">Overall Rating</label>
          <div class="d-flex justify-content-between gap-2">
            <% const colors=['#ef4444', '#f97316' , '#facc15' , '#a3e635' , '#22c55e' ]; %>
              <% for(let i=1; i<=5; i++) { %>
                <div class="flex-fill">
                  <input type="radio" class="btn-check" name="rating" id="pageRate<%= i %>" value="<%= i %>" required>
                  <label class="btn btn-outline-secondary w-100 rating-btn-large" for="pageRate<%= i %>"
                    style="--rating-color: <%= colors[i-1] %>;"><%= i %></label>
                </div>
                <% } %>
          </div>
        </div>
        <div class="col-12">
          <label class="form-label small fw-bold">Comments & Suggestions</label>
          <textarea name="message" class="form-control glass-input" rows="4" placeholder="What did you like? What can be improved?" required></textarea>
          <input type="hidden" name="subject" value="Website Feedback (Full)">
        </div>
        <div class="col-12 mt-4">
          <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold">Submit Feedback</button>
        </div>
      </div>
    </form>
  </div>

  <div class="feedback-success d-none text-center py-5" id="pageFeedbackSuccessStep">
    <div class="fs-1 mb-3">✅</div>
    <h3 class="fw-bold">Feedback Submitted!</h3>
    <p class="text-muted">Thank you for taking the time to share your thoughts.</p>
    <a href="/" class="btn btn-outline-primary rounded-pill mt-3">Back to Home</a>
  </div>
</div>

<style>
.rating-btn-large {
  padding: 10px;
  font-weight: bold;
  font-size: 1.2rem;
  transition: all 0.3s;
}
.rating-btn-large:hover, .btn-check:checked + .rating-btn-large {
  background-color: var(--rating-color) !important;
  border-color: var(--rating-color) !important;
  color: white !important;
  transform: translateY(-3px);
  box-shadow: 0 5px 15px rgba(0,0,0,0.3);
}
</style>

<script>
  const pageFeedbackForm = document.getElementById('pageFeedbackForm');
  if (pageFeedbackForm) {
    pageFeedbackForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(pageFeedbackForm);
      const data = {};
      formData.forEach((value, key) => data[key] = value);

      try {
        const btn = e.target.querySelector('button[type="submit"]');
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Submitting...';
        btn.disabled = true;

        await fetch('/contact-me', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        document.getElementById('pageFeedbackFormStep').classList.add('d-none');
        document.getElementById('pageFeedbackSuccessStep').classList.remove('d-none');
        localStorage.setItem('feedbackSubmitted', 'true');
      } catch (err) { 
        console.error("Feedback failed", err);
        alert("Submission failed. Please try again.");
      }
    });
  }
</script>
