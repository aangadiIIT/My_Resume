<!-- PDF Viewer Modal -->
<div class="modal fade" id="pdfModal" tabindex="-1" aria-hidden="true" style="background:rgba(0,0,0,0.88);backdrop-filter:blur(10px);z-index:1060;">
  <div class="modal-dialog modal-dialog-centered modal-xl" style="max-width:95%;margin:1rem auto;">
    <div class="modal-content bg-dark border-0 shadow-lg pdf-modal-content">
      <div class="modal-header border-0 bg-transparent p-3 flex-shrink-0" style="color:#fff;">
        <h5 class="modal-title fw-bold text-white" id="pdfModalLabel">Certificate Viewer</h5>
        <div class="d-flex gap-2 align-items-center ms-auto">
          <a id="pdfDownloadLink" href="#" target="_blank" rel="noopener"
            class="btn btn-sm btn-outline-light rounded-pill px-3">
            <i class="fas fa-external-link-alt me-1"></i>Open Full Screen
          </a>
          <button type="button" class="btn-close btn-close-white shadow-none"
            data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
      </div>
      <div class="pdf-modal-body">
        <iframe id="pdfFrame" src="" title="Certificate PDF"
          style="width:100%;height:100%;border:none;display:block;"></iframe>
      </div>
    </div>
  </div>
</div>

<style nonce="<%= nonce %>">
  .pdf-modal-content {
    display: flex;
    flex-direction: column;
    height: 90vh;
    max-height: 90vh;
  }
  .pdf-modal-body {
    flex: 1 1 auto;
    min-height: 0;
    overflow: hidden;
    background: #1a1a2e;
  }
  @media (max-width: 768px) {
    .pdf-modal-content { height: 95vh; max-height: 95vh; }
  }
  .modal-xl { max-width: 95% !important; }
  @media (min-width: 1200px) { .modal-xl { max-width: 1200px !important; } }
</style>

<script nonce="<%= nonce %>">
  document.addEventListener('DOMContentLoaded', () => {
    const pdfModalElement = document.getElementById('pdfModal');
    if (!pdfModalElement) return;

    const pdfModal     = new bootstrap.Modal(pdfModalElement);
    const pdfFrame     = document.getElementById('pdfFrame');
    const pdfModalLabel    = document.getElementById('pdfModalLabel');
    const pdfDownloadLink  = document.getElementById('pdfDownloadLink');

    document.addEventListener('click', (e) => {
      const trigger = e.target.closest('.pdf-trigger');
      if (!trigger) return;
      e.preventDefault();
      const pdfUrl = trigger.getAttribute('data-pdf');
      const title  = trigger.getAttribute('data-title');
      pdfModalLabel.innerText   = title;
      pdfFrame.src              = pdfUrl;
      pdfDownloadLink.href      = pdfUrl;
      pdfModal.show();
    });

    pdfModalElement.addEventListener('hidden.bs.modal', () => {
      pdfFrame.src = '';
    });
  });
</script>
