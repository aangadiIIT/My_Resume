<div class="chatbot-widget" id="chatbotWidget">
  <div class="chat-window glass-card" id="chatWindow">
    <div class="chat-header">
      <div class="d-flex align-items-center gap-2">
        <div class="bot-avatar-mini">🤖</div>
        <div class="d-flex flex-column line-height-1">
          <div class="fw-bold small text-white d-flex align-items-center text-nowrap">Akhilesh's AI <span
              class="online-dot"></span></div>
          <div class="x-small text-muted" style="font-size: 0.65rem;">Virtual Assistant</div>
        </div>
      </div>
      <div class="d-flex align-items-center gap-2">
        <div class="user-mode-badge" id="userModeBadge" style="display:none"></div>
        <div class="header-actions">
          <div class="clear-confirm-popover" id="clearConfirmPopover">
            <span class="small me-2">Clear chat?</span>
            <button class="btn btn-sm btn-danger py-0 px-2" id="confirmClearBtn" style="font-size: 0.7rem;">Yes,
              Clear</button>
          </div>
          <button class="header-btn" id="clearChatBtn" title="Clear Conversation"><i
              class="fas fa-trash-alt"></i></button>
          <button class="header-btn" id="maximizeChatBtn" title="Maximize"><i class="fas fa-expand-alt"></i></button>
          <button class="header-btn" id="closeChatBtn" title="Close">&times;</button>
        </div>
      </div>
    </div>

    <div class="chat-body" id="chatBody">
      <div id="initialBotMessage" class="message bot-message text-white">Hi! I'm Akhilesh's virtual assistant. Ask me
        anything about him!</div>
      <button id="scrollToBottomBtn" class="scroll-bottom-btn"><i class="fas fa-chevron-down"></i></button>
    </div>

    <div class="chat-footer">
      <div class="input-container">
        <input type="text" id="chatInput" placeholder="Ask about experience, skills, projects..." class="text-white">
        <button id="sendChatBtn" class="send-btn">
          <i class="fas fa-paper-plane send-icon"></i>
          <i class="fas fa-stop stop-icon" style="display:none"></i>
        </button>
      </div>
    </div>
  </div>

  <div class="chat-toggle" id="chatToggle" title="Chat with Akhilesh AI">
    <i class="fas fa-comment-dots"></i>
  </div>
</div>

<link rel="stylesheet" href="/stylesheets/chatbot.css">
<script src="/scripts/chatbot-engine.js"></script>
<script src="/scripts/chatbot-ui.js"></script>