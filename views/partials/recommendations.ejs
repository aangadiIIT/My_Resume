<!-- Recommendations Section Partial -->
<% if(data.recommendations && data.recommendations.recommendations && data.recommendations.recommendations.length > 0) { %>
<section class="py-5" id="recommendations">
  <div class="text-center mb-5" data-aos="fade-up">
    <h2 class="section-title">What Colleagues Say</h2>
    <p class="text-muted">High-impact testimonials from managers and industry peers.</p>
  </div>

  <div id="recommendationCarousel" class="carousel slide" data-bs-ride="carousel" data-aos="zoom-in">
    <!-- Carousel Indicators -->
    <div class="carousel-indicators" style="bottom: -50px;">
      <% data.recommendations.recommendations.forEach((_, index) => { %>
        <button type="button" data-bs-target="#recommendationCarousel" data-bs-slide-to="<%= index %>" 
          class="<%= index === 0 ? 'active' : '' %> bg-primary" aria-current="<%= index === 0 ? 'true' : 'false' %>" 
          aria-label="Slide <%= index + 1 %>"></button>
      <% }) %>
    </div>

    <!-- Carousel Items -->
    <div class="carousel-inner">
      <% data.recommendations.recommendations.forEach((rec, index) => { %>
        <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
          <div class="d-flex justify-content-center px-3">
            <a href="/recommendations" class="text-decoration-none glass-card p-5 text-center position-relative shadow-lg border-0 transition-transform hover-scale" style="max-width: 900px; overflow: visible; cursor: pointer;">
              
              <!-- Quote Icon Decor -->
              <div class="position-absolute top-0 start-50 translate-middle" style="z-index: 10;">
                <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center shadow-sm border border-white border-4" style="width: 60px; height: 60px;">
                    <i class="fas fa-quote-left text-white fs-4"></i>
                </div>
              </div>

              <div class="mt-4">
                <blockquote class="blockquote mb-4">
                  <p class="fs-5 text-muted fst-italic shadow-none border-0" style="line-height: 1.8;">
                    "<%= rec.recommendation_raw.length > 300 ? rec.recommendation_raw.substring(0, 300) + '...' : rec.recommendation_raw %>"
                  </p>
                </blockquote>
                
                <div class="mt-5 border-top pt-4" style="border-color: var(--glass-border) !important;">
                  <h5 class="fw-bold mb-1 text-gradient"><%= rec.author.name %></h5>
                  <p class="text-primary small fw-bold mb-0">
                    <%= rec.author.role %> @ <%= rec.author.company %>
                  </p>
                  <p class="text-muted small">
                    <i class="fas fa-link me-1"></i> <%= rec.author.relationship %>
                  </p>
                </div>

                <!-- Read More CTA -->
                <div class="mt-4 text-accent fw-bold small">
                    READ FULL RECOMMENDATION <i class="fas fa-arrow-right ms-1"></i>
                </div>

                <!-- Keywords/Strengths Tags -->
                <div class="mt-3 d-flex flex-wrap justify-content-center gap-2">
                  <% rec.impact_keywords.forEach(keyword => { %>
                    <span class="badge bg-primary-soft text-primary rounded-pill border border-primary border-opacity-10 px-3 py-1" style="font-size: 0.7rem;">
                      #<%= keyword %>
                    </span>
                  <% }) %>
                </div>
              </div>

            </a>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- Carousel Controls -->
    <button class="carousel-control-prev" type="button" data-bs-target="#recommendationCarousel" data-bs-slide="prev" style="width: 5%; left: -2%;">
      <span class="carousel-control-prev-icon bg-primary rounded-circle" aria-hidden="true" style="width: 40px; height: 40px; background-size: 50%;"></span>
      <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#recommendationCarousel" data-bs-slide="next" style="width: 5%; right: -2%;">
      <span class="carousel-control-next-icon bg-primary rounded-circle" aria-hidden="true" style="width: 40px; height: 40px; background-size: 50%;"></span>
      <span class="visually-hidden">Next</span>
    </button>
  </div>
</section>

<!-- Custom Styling for the Carousel to handle the indicators and spacing -->
<style>
  #recommendationCarousel .carousel-item {
    padding: 60px 0; /* Add space for the floating quote icon */
  }
  .carousel-indicators [data-bs-target] {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      margin: 0 6px;
      opacity: 0.3;
      transition: all 0.3s ease;
  }
  .carousel-indicators .active {
      opacity: 1;
      transform: scale(1.3);
  }
  .bg-primary-soft {
      background-color: rgba(var(--bs-primary-rgb), 0.1) !important;
  }
</style>
<% } %>
