<div class="hiring-popup glass-card" id="hiringPopup" role="dialog" aria-modal="true" aria-labelledby="hiringPopupTitle">
  <button class="close-btn" id="closeHiringBtn" aria-label="Close hiring popup">&times;</button>
  <div class="hiring-content" id="hiringFormStep">
    <div class="hiring-icon">💼</div>
    <h5 class="text-adaptive-hiring" id="hiringPopupTitle">Start a Conversation</h5>
    <p class="small text-muted-adaptive-hiring mb-3">Direct message regarding opportunities.</p>

    <form id="hiringContactForm">
      <div class="mb-2">
        <label for="hiringName" class="visually-hidden">Your Full Name</label>
        <input type="text" id="hiringName" name="name" class="form-control form-control-sm glass-input" placeholder="Your Full Name" aria-label="Your full name" required>
      </div>
      <div class="mb-2">
        <label for="hiringEmail" class="visually-hidden">Your Work Email</label>
        <input type="email" id="hiringEmail" name="email" class="form-control form-control-sm glass-input" placeholder="Your Work Email" aria-label="Your work email address" required>
      </div>
      <input type="hidden" name="subject" value="Hiring Opportunity">
      <div class="mb-3">
        <label for="hiringMessage" class="visually-hidden">Message about the role</label>
        <textarea id="hiringMessage" name="message" class="form-control form-control-sm glass-input" rows="3" placeholder="Tell me about the role..." aria-label="Tell me about the role" required></textarea>
      </div>
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary btn-sm flex-fill rounded-pill">Send Message</button>
      </div>
    </form>
  </div>

  <div class="hiring-success d-none text-center py-4" id="hiringSuccessStep">
    <div class="fs-1 mb-2">📬</div>
    <h5 class="fw-bold text-adaptive-hiring">Message Sent!</h5>
    <p class="small text-muted-adaptive-hiring">I will get back to you shortly.</p>
    <button class="btn btn-outline-primary btn-sm rounded-pill mt-2" id="closeHiringPopupBtn">Close</button>
  </div>
</div>

<style nonce="<%= nonce %>">
.hiring-popup { position: fixed; bottom: -500px; right: 25px; width: 330px; z-index: 3500; padding: 1.5rem; transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275); background: var(--glass-bg) !important; border: 1px solid var(--glass-border) !important; box-shadow: var(--glass-shadow); border-radius: 16px; }
.hiring-popup.active { bottom: 95px; }
.text-adaptive-hiring { color: var(--text-primary) !important; }
.text-muted-adaptive-hiring { color: var(--text-secondary) !important; }
.hiring-popup .close-btn { position: absolute; top: 10px; right: 15px; background: none; border: none; font-size: 1.5rem; color: var(--text-tertiary); cursor: pointer; }
.hiring-icon { font-size: 1.5rem; margin-bottom: 0.5rem; }
</style>

<script nonce="<%= nonce %>">
  function openHiringPopup() {
    if (typeof UIManager !== 'undefined') UIManager.closeAll('hiring');
    const popup = document.getElementById('hiringPopup');
    popup.classList.add('active');
    // Focus first input for keyboard/screen reader users
    setTimeout(() => { document.getElementById('hiringName')?.focus(); }, 100);
  }
      function closeHiringPopup() {
    const popup = document.getElementById('hiringPopup');
    popup.classList.remove('active');
    // Return focus to trigger element
    const trigger = document.getElementById('recruiterFabMainBtn') || document.getElementById('fabWhyBtn');
    if (trigger) trigger.focus();
  }

  document.getElementById('closeHiringBtn').addEventListener('click', closeHiringPopup);
  document.getElementById('closeHiringPopupBtn')?.addEventListener('click', closeHiringPopup);

  let hiringIsSubmitting = false;
  const hiringForm = document.getElementById('hiringContactForm');
  if (hiringForm) {
    hiringForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (hiringIsSubmitting) return;
      hiringIsSubmitting = true;
      const formData = new FormData(hiringForm);
      const data = {};
      formData.forEach((value, key) => data[key] = value);

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        const result = await response.json();
        if (response.ok && result.success) {
          document.getElementById('hiringFormStep').classList.add('d-none');
          document.getElementById('hiringSuccessStep').classList.remove('d-none');
        } else {
          if (typeof Toast !== 'undefined') {
            Toast.show({ message: result.message || 'Something went wrong. Please try again.', type: 'error' });
          }
        }
      } catch (err) {
        if (typeof Toast !== 'undefined') {
          Toast.show({ message: 'Unable to send message. Please try again.', type: 'error' });
        }
        console.error('Hiring contact failed', err);
      }
      finally { hiringIsSubmitting = false; }
    });
  }
</script>
