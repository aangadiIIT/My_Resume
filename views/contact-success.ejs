<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include('partials/header') %>

    <div class="container py-5 my-auto flex-grow-1 d-flex flex-column justify-content-center align-items-center">
        <div class="glass-card p-5 text-center shadow-lg" data-aos="zoom-in">
            <div class="mb-4 text-success" style="font-size: 5rem;">
                <i class="fas fa-paper-plane animate-bounce"></i>
            </div>
            <h1 class="display-4 fw-bold text-gradient mb-3">Message Sent!</h1>
            <p class="lead text-muted mb-4">Thanks for reaching out, <strong><%= userName %></strong>. <br>I've received your message and will get back to you shortly.</p>
            
            <div class="p-3 mb-4 rounded" style="background: var(--shape-3); border: 1px dashed #10b981;">
                <p class="text-success small mb-0"><i class="fas fa-robot me-2"></i> An automated confirmation has been logged for your request.</p>
            </div>

            <a href="/" class="btn-primary-custom px-5 py-3 fs-5 shadow-sm">
                <i class="fas fa-home me-2"></i> Back to Home
            </a>
        </div>
    </div>

    <%- include('partials/footer') %>

    <style>
        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% {transform: translateY(0);}
            40% {transform: translateY(-20px);}
            60% {transform: translateY(-10px);}
        }
        .animate-bounce {
            animation: bounce 2s infinite;
        }
    </style>
</body>
</html>
