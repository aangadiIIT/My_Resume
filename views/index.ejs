<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('partials/head') %>
</head>

  <style>
    /* Magnetic Buttons */
    .magnetic-btn {
      transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.3s ease;
    }
  </style>
  <%- include('partials/header') %>

    <!-- Hero Section -->
    <div class="hero-section position-relative overflow-hidden d-flex align-items-center pt-5 mt-4 min-vh-75">
      <div class="container position-relative" style="z-index: 2;">
        <div class="row align-items-center flex-column-reverse flex-lg-row">

          <!-- Text Content -->
          <div class="col-lg-7 mt-5 mt-lg-0" data-aos="fade-right">
            <p class="mb-2 text-uppercase tracking-widest text-muted fw-bold">Hello, I'm</p>
            <h1 class="display-3 fw-bolder mb-3 text-gradient">
              <%= data.profile.profile.name %>
            </h1>
            <h2 class="h3 mb-4" style="min-height: 40px; color: var(--accent-hover);"><span id="typed-headline"></span>
            </h2>

            <p class="lead text-muted mb-4 pe-lg-5">
              <%= data.profile.profile.about_structured ? data.profile.profile.about_structured.summary :
                data.profile.profile.about_raw %>
            </p>

            <% if(data.profile.profile.headline_structured && data.profile.profile.headline_structured.current_company)
              { %>
              <div
                class="glass-card border-0 px-3 py-2 mb-4 rounded-pill fw-bold text-accent d-inline-flex align-items-center shadow-sm"
                style="padding: 0.5rem 1.25rem !important; background: var(--shape-1);">
                <i class="fas fa-building me-2"></i>
                Currently at <%= data.profile.profile.headline_structured.current_company %>
              </div>
              <% } %>

                <div class="d-flex flex-wrap gap-3 mb-4 align-items-center">
                  <a href="/experience" class="btn-primary-custom magnetic-btn" data-magnetic>
                    <i class="fas fa-briefcase me-2"></i> View Experience
                  </a>
                  <a href="/my-works" class="btn-outline-custom magnetic-btn" data-magnetic>
                    <i class="fas fa-code me-2"></i> View Projects
                  </a>
                  <a href="/contact-me" class="btn-outline-custom magnetic-btn" data-magnetic
                    style="border-color: var(--text-tertiary); color: var(--text-secondary);">
                    <i class="fas fa-envelope me-2"></i> Contact Me
                  </a>
                  <a href="/view-asset/documents/Resume.pdf"
                    class="btn btn-link text-muted text-decoration-none fw-bold ms-2" download="Resume.pdf">
                    <i class="fas fa-file-pdf me-1"></i> Download Resume
                  </a>
                </div>

                <% if(data.profile.profile.tags && data.profile.profile.tags.length> 0) { %>
                  <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top"
                    style="border-color: var(--glass-border) !important;">
                    <span class="text-muted fw-bold me-2 mt-1">Focus:</span>
                    <% data.profile.profile.tags.slice(0, 5).forEach(tag=> { %>
                      <span class="skill-pill m-0">
                        <%= tag %>
                      </span>
                      <% }) %>
                  </div>
                  <% } %>
          </div>

          <!-- Profile Photo -->
          <div class="col-lg-5 text-center mb-5 mb-lg-0" data-aos="fade-left" data-aos-delay="200">
            <div class="hero-image-container d-inline-block position-relative mb-4">
              <div class="hero-image-backdrop"></div>
              <img src="<%= data.profile.profile.photoPath || '/images/profile-photo.jpg' %>"
                alt="<%= data.profile.profile.name %>" class="hero-image">
            </div>

            <% if(data.yrsExperience) { %>
              <div class="d-flex align-items-center justify-content-center glass-card px-4 py-2 mx-auto shadow-sm"
                style="border-radius: 30px; width: max-content; max-width: 100%; border-color: var(--accent-primary) !important;"
                data-aos="fade-up" data-aos-delay="300">
                <i class="fas fa-briefcase text-gradient fs-3 me-3"></i>
                <div class="text-start lh-1">
                  <span class="fw-bolder fs-4 text-gradient d-block">
                    <%= data.yrsExperience %>+ Years
                  </span>
                  <span class="fw-bold text-muted text-uppercase"
                    style="font-size: 0.75rem; letter-spacing: 1.5px;">Experience</span>
                </div>
              </div>
              <% } %>
          </div>

        </div>
      </div>
    </div>

    <!-- Superpowers Section -->
    <% if(data.profile.profile.about_structured && data.profile.profile.about_structured.superpowers) { %>
      <div class="container py-5 my-5">
        <div class="text-center mb-5" data-aos="fade-up">
          <h2 class="section-title">My Superpowers</h2>
          <p class="text-muted lead">The core strengths I bring to every team and project.</p>
        </div>

        <div class="row g-4 justify-content-center">
          <% data.profile.profile.about_structured.superpowers.slice(0, 6).forEach((power, index)=> { %>
            <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="<%= index * 100 %>">
              <div class="glass-card h-100 p-4">
                <div class="mb-3 fs-2 d-inline-block p-3 rounded-circle"
                  style="background: var(--shape-1); color: var(--accent-primary);">
                  <i class="fas <%= power.icon %>"></i>
                </div>
                <h4 class="h5 fw-bold mb-2">
                  <%= power.title %>
                </h4>
                <p class="text-muted small mb-0">
                  <%= power.description %>
                </p>
              </div>
            </div>
            <% }) %>
        </div>
      </div>
      <% } %>

        <!-- Highlights Preview Section -->
        <% if((data.certifications && data.certifications.certifications) || (data.awards && data.awards.awards)) { %>
          <div class="container py-5 my-5 border-top" style="border-color: var(--glass-border) !important;">
            <div class="text-center mb-5" data-aos="fade-up">
              <h2 class="section-title">Career Highlights</h2>
              <p class="text-muted lead">A quick glance at recent milestones and recognition.</p>
            </div>

            <div class="row g-4 justify-content-center">
              <!-- Top Certification Preview -->
              <% if(data.certifications && data.certifications.certifications.length> 0) { %>
                <% const topCert=data.certifications.certifications[0]; %>
                  <div class="col-md-6" data-aos="fade-right">
                    <div class="glass-card h-100 p-4 border-start border-4"
                      style="border-color: var(--accent-primary) !important;">
                      <h3 class="h5 fw-bold text-muted mb-3"><i class="fas fa-certificate me-2 text-accent"></i> Latest
                        Certification</h3>
                      <h4 class="h5 fw-bold mb-2">
                        <%= topCert.name %>
                      </h4>
                      <p class="text-muted small mb-0"><i class="fas fa-building me-1"></i>
                        <%= topCert.issuer %> &bull; <%= topCert.issue_date %>
                      </p>
                      <div class="mt-4 d-flex justify-content-between align-items-center">
                        <% if(topCert.document_path) { %>
                          <button class="btn btn-sm btn-outline-primary rounded-pill fw-bold pdf-trigger"
                            data-pdf="<%= topCert.document_path %>" data-title="<%= topCert.name %>">
                            <i class="far fa-file-pdf me-1"></i> PDF
                          </button>
                          <% } %>
                            <a href="/certifications" class="text-accent fw-bold text-decoration-none small">View All
                              Certifications <i class="fas fa-arrow-right ms-1"></i></a>
                      </div>
                    </div>
                  </div>
                  <% } %>

                    <!-- Top Award Preview -->
                    <% if(data.awards && data.awards.awards.length> 0) { %>
                      <% const topAward=data.awards.awards[0]; %>
                        <div class="col-md-6" data-aos="fade-left">
                          <div class="glass-card h-100 p-4 border-start border-4"
                            style="border-color: #10b981 !important;">
                            <h3 class="h5 fw-bold text-muted mb-3"><i class="fas fa-trophy me-2 text-success"></i>
                              Latest Award</h3>
                            <div class="d-flex gap-3 align-items-start">
                              <div class="flex-grow-1">
                                <h4 class="h5 fw-bold mb-2">
                                  <%= topAward.title %>
                                </h4>
                                <p class="text-muted small mb-0 fst-italic">"<%= topAward.description_raw.split('.')[0]
                                    %>."</p>
                              </div>
                              <% if(topAward.image_path) { %>
                                <div class="flex-shrink-0">
                                  <img src="<%= topAward.image_path %>" alt="Award" class="rounded shadow-sm border"
                                    style="width: 80px; height: 60px; object-fit: cover;">
                                </div>
                                <% } %>
                            </div>
                            <div class="mt-4 text-end">
                              <a href="/honors-awards" class="text-success fw-bold text-decoration-none small">View All
                                Awards <i class="fas fa-arrow-right ms-1"></i></a>
                            </div>
                          </div>
                        </div>
                        <% } %>
            </div>
          </div>
          <% } %>

            <div class="container mb-5">
              <%- include('partials/recommendations') %>
            </div>

            <!-- Funnel Navigation CTA -->
            <div class="container mb-5 pb-5">
              <div class="glass-card text-center p-5 shadow-lg mx-auto"
                style="max-width: 800px; background: var(--accent-gradient);" data-aos="zoom-in">
                <h3 class="h2 fw-bolder text-white mb-3">Ready to dive deeper?</h3>
                <p class="text-white-50 lead mb-4">Discover the roles, responsibilities, and impact I've made throughout
                  my career.</p>
                <a href="/experience"
                  class="btn btn-light rounded-pill px-5 py-3 fw-bolder text-primary fs-5 shadow-sm transition-transform hover-scale">
                  Explore My Experience <i class="fas fa-arrow-right ms-2"></i>
                </a>
              </div>
            </div>

            <%- include('partials/footer') %>
              <%- include('partials/pdf-viewer') %>

                <!-- Micro-Interactions Script -->
                <script>
                  document.addEventListener('DOMContentLoaded', () => {

                    // Magnetic Buttons
                    document.querySelectorAll('[data-magnetic]').forEach(btn => {
                      btn.addEventListener('mousemove', (e) => {
                        const rect = btn.getBoundingClientRect();
                        const x = e.clientX - rect.left - rect.width / 2;
                        const y = e.clientY - rect.top - rect.height / 2;
                        btn.style.transform = `translate(${x * 0.2}px, ${y * 0.2}px)`;
                      });
                      btn.addEventListener('mouseleave', () => {
                        btn.style.transform = `translate(0px, 0px)`;
                      });
                    });
                  });
                </script>
                <script id="index-script" data-strings="<%= JSON.stringify(data.typedStrings || []) %>" src="/scripts/app/index.js"></script>
</body>

</html>