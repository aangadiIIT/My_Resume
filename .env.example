# ── AI Services ──────────────────────────────────────────────────────────────
# Get a free Gemini API key at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ── Admin / Monitoring ────────────────────────────────────────────────────────
# If set, blocks external access to /api/site-metrics and /api/model-status.
# External requests must supply: x-admin-key: <value>
# Same-origin requests (the site's own metrics widget) are always allowed.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=your_random_secret_here

# ── Contact Form (Google Forms backend) ──────────────────────────────────────
# All five values must match the same Google Form. Update together if rotating.
GOOGLE_FORM_URL=https://docs.google.com/forms/d/e/YOUR_FORM_ID/formResponse
GOOGLE_FORM_ENTRY_NAME=entry.XXXXXXXXX
GOOGLE_FORM_ENTRY_EMAIL=entry.XXXXXXXXX
GOOGLE_FORM_ENTRY_SUBJECT=entry.XXXXXXXXX
GOOGLE_FORM_ENTRY_RATING=entry.XXXXXXXXX
GOOGLE_FORM_ENTRY_MESSAGE=entry.XXXXXXXXX

# ── Runtime Mode ─────────────────────────────────────────────────────────────
# DO NOT set production locally — activates HTTPS redirect that breaks localhost.
# Set this in production environments only (GitHub Actions, Railway, Azure).
# NODE_ENV=production
